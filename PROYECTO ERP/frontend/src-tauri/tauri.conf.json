{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jarvis Core",
  "version": "0.1.0",
  "identifier": "com.jarvis.core",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Jarvis Core",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "Jarvis Core",
    "copyright": "© 2026 Jarvis Core",
    "category": "Business",
    "shortDescription": "Jarvis Core ERP — caja, stock y facturación",
    "longDescription": "Jarvis Core es la app desktop para cajas dedicadas: facturación AFIP, stock, caja, OCR y reportes con cola offline para que la caja siga vendiendo cuando se cae internet.",
    "windows": {
      "wix": {
        "language": "es-AR"
      },
      "nsis": {
        "languages": ["Spanish", "English"],
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "shell": {
      "scope": [
        { "url": "http://localhost:5000/*" },
        { "url": "http://localhost:9123/*" }
      ]
    }
  }
}
