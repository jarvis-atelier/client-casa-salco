FLASK_APP=wsgi:app
FLASK_ENV=development
FLASK_DEBUG=1

# Database - dev default SQLite local (sin Docker necesario)
# Produccion: postgresql+psycopg://user:pass@host:5432/castulo  (Neon, Supabase, Railway, VPS)
DATABASE_URL=sqlite:///instance/castulo.db

# Redis (opcional en dev). Si no hay Redis, SocketIO cae a modo in-memory (OK para un proceso).
# REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=change-me-in-production-please
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App
SECRET_KEY=change-me-too
APP_NAME=Castulo

# AFIP / ARCA — Facturacion electronica
# AFIP_MODE: mock (dev), pyafipws (prod), disabled (CI / sin AFIP)
AFIP_MODE=mock
# Homologacion (true) = ambiente de pruebas AFIP. Produccion (false) = ambiente real.
AFIP_HOMO=true
AFIP_CUIT=20000000001
# Paths absolutos o relativos al backend/. Para prod, subir el cert+key AFIP:
# AFIP_CERT_PATH=instance/afip_certs/<cuit>/certificado.crt
# AFIP_KEY_PATH=instance/afip_certs/<cuit>/privada.key

# OCR — Lectura de comprobantes con IA
# OCR_MODE: mock (dev sin key) | anthropic (Claude Vision) | gemini (Google Gemini Vision)
OCR_MODE=mock

# Anthropic Claude Vision (alternativa)
# ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini Vision (recomendado: ultrabarato + free tier amplio)
# Obtener key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIzaSy-xxxxx
GEMINI_MODEL=gemini-1.5-flash

# ==========================================================================
# === PRODUCCION (referencia - NO usar en dev) =============================
# ==========================================================================
# Estos valores son ejemplos. En produccion se setean via secrets del
# provider (flyctl secrets, Railway env vars, docker-compose .env.prod).
# NUNCA commitear el .env real con estos valores.
#
# --- Database ---
# Postgres en Neon (free 3GB / $19 por 10GB):
# DATABASE_URL=postgresql+psycopg://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
#
# Postgres en Supabase / Railway / VPS propio: misma forma, sin sslmode si es interno.
#
# --- Redis ---
# Upstash (free 10k commands/dia):
# REDIS_URL=redis://default:pass@host:port
#
# Necesario solo si:
#   - SocketIO multi-instancia (escalado horizontal)
#   - Celery (background jobs)
# Sino, dejar comentado y SocketIO usa fallback in-memory.
#
# --- CORS ---
# Lista de origins permitidos separados por coma. Sin trailing slash.
# CORS_ORIGINS=https://app.jarvis-core.com
# Multiples: CORS_ORIGINS=https://app.jarvis-core.com,https://staging.jarvis-core.com
#
# --- AFIP produccion ---
# Cuando tengas el cert real (NO el de homologacion):
# AFIP_MODE=pyafipws
# AFIP_HOMO=false
# AFIP_CERT_PATH=/app/instance/afip_certs/<cuit>/certificado.crt
# AFIP_KEY_PATH=/app/instance/afip_certs/<cuit>/privada.key
#
# El cert dura 2 anos - ver docs/operations.md para renewal.
#
# --- OCR produccion ---
# Gemini (recomendado: $0.01 / imagen aprox):
# OCR_MODE=gemini
# GEMINI_API_KEY=AIzaSy-xxxxx
#
# Anthropic (alternativa, mas caro pero mejor en algunos casos):
# OCR_MODE=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxx
#
# --- Secrets generados ---
# Para JWT_SECRET_KEY y SECRET_KEY usar siempre:
#   openssl rand -hex 32
# NUNCA reusar el "change-me-in-production-please" en prod.
#
# --- Sentry (opcional, recomendado) ---
# SENTRY_DSN=https://xxx@sentry.io/123456
# SENTRY_TRACES_SAMPLE_RATE=0.1
