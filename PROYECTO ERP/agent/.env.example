# Jarvis POS Agent — environment configuration

# HTTP server
JARVIS_AGENT_HOST=127.0.0.1
JARVIS_AGENT_PORT=9123

# Printer mode: mock | usb | network
PRINTER_MODE=mock

# 3NSTAR PRP-080 (USB) — vendor/product IDs (varies by model)
PRINTER_USB_VENDOR=0x0fe6
PRINTER_USB_PRODUCT=0x811e
PRINTER_USB_INTERFACE=0
PRINTER_USB_IN_EP=0x82
PRINTER_USB_OUT_EP=0x02

# 3NSTAR Ethernet — TCP/IP raw printing (default port 9100)
PRINTER_NETWORK_HOST=192.168.1.50
PRINTER_NETWORK_PORT=9100

# Paper width in mm (58 or 80). Default 80 mm.
PRINTER_PAPER_WIDTH_MM=80

# Scale mode: mock | kretz | systel | network
# Modelos comunes en Argentina:
#   kretz   → Aqua, Aqua II, Aria-XS, Carro (RS-232 9600 8N1)
#   systel  → Croma, Aspen, Mensa, Volar (RS-232 9600 8N1)
#   network → cualquier modelo via Moxa NPort / USR-TCP-COM en TCP/IP
SCALE_MODE=mock
SCALE_PORT=COM3
SCALE_BAUDRATE=9600
SCALE_HOST=192.168.1.60
SCALE_NETWORK_PORT=1001
SCALE_TIMEOUT_SEC=1.0

# Output directory for the mock printer (PDFs + JSON dumps)
OUTPUT_DIR=output

# CORS origins allowed to call the agent (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:1420
